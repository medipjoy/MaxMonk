{
  "expo": {
    "name": "ClearDay",
    "slug": "clearday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "clearday",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maxmonk.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.maxmonk.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070D"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
